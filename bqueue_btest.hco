{
  "nstates": 70,
  "hvm": {
    "modules": {
        "bqueue": {
            "file": "bqueue.hny",
            "lines": [
                "def BQueue(n) returns bq:",
                "    bq = { .elements: [], .size: n }",
                "",
                "def bq_put(bq, v):",
                "    atomically when len(bq->elements) < bq->size:",
                "        bq->elements += [v,]",
                "",
                "def bq_get(bq) returns next:",
                "    atomically when bq->elements != []:",
                "        next = bq->elements[0]",
                "        del bq->elements[0]",
                "",
                "def bq_peek(bq) returns next:",
                "    atomically when bq->elements != []:",
                "        next = bq->elements[0]",
                "",
                "def bq_clear(bq):",
                "    atomically:",
                "        bq->elements = []"
              ],
            "identifiers": {
                "BQueue": "constant",
                "bq": "local-const",
                "n": "local-const",
                "bq_put": "constant",
                "bq_peek": "constant",
                "this": "local-var",
                "v": "local-const",
                "bq_get": "constant",
                "___": "___",
                "bq_clear": "constant"
              }
          },
        "__main__": {
            "file": "bqueue_btest.hny",
            "lines": [
                "import bqueue",
                "",
                "const SIZE = 1",
                "const NPUT = 1",
                "const NGET = 1",
                "const NPEEK = 0",
                "const NCLEAR = 0",
                "",
                "q = bqueue.BQueue(SIZE)",
                "",
                "def put_test(self):",
                "    print(\"call put\", self)",
                "    bqueue.bq_put(?q, self)",
                "    print(\"done put\", self)",
                "",
                "def get_test(self):",
                "    print(\"call get\", self)",
                "    let v = bqueue.bq_get(?q):",
                "        print(\"done get\", self, v)",
                "",
                "def peek_test(self):",
                "    print(\"call peek\", self)",
                "    let v = bqueue.bq_peek(?q):",
                "        print(\"done peek\", self, v)",
                "",
                "def clear_test(self):",
                "    print(\"call clear\", self)",
                "    bqueue.bq_clear(?q)",
                "    print(\"done clear\", self)",
                "",
                "for i in {1..NPUT}:",
                "    spawn put_test(i)",
                "",
                "for i in {1..NGET}:",
                "    spawn get_test(i)",
                "",
                "for i in {1..NPEEK}:",
                "    spawn peek_test(i)",
                "",
                "for i in {1..NCLEAR}:",
                "    spawn clear_test(i)"
              ],
            "identifiers": {
                "peek_test": "constant",
                "NGET": "constant",
                "bqueue": "module",
                "NPEEK": "constant",
                "self": "local-const",
                "i": "local-const",
                "NCLEAR": "constant",
                "put_test": "constant",
                "NPUT": "constant",
                "this": "local-var",
                "v": "local-const",
                "q": "global",
                "get_test": "constant",
                "clear_test": "constant",
                "___": "___",
                "SIZE": "constant"
              }
          }
      },
