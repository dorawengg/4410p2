    "modules": {
        "bqueue": {
            "file": "bqueue.hny",
            "lines": [
                "# Specification for a blocking bounded queue",
                "# All operations except BQueue(n) must be atomic (linearizable)",
                "",
                "def BQueue(n):",
                "    result = {",
                "        .data: [None,] * n,",
                "        .size: n,",
                "        .count: 0,",
                "        .head: 0,",
                "        .tail: 0",
                "    }",
                "",
                "def bq_put(bq, v):",
                "    done = False",
                "    while not done:",
                "        atomically:",
                "            if bq->count < bq->size:",
                "                bq->data[bq->tail] = v",
                "                bq->tail = (bq->tail + 1) % bq->size",
                "                bq->count += 1",
                "                done = True",
                "",
                "def bq_get(bq):",
                "    done = False",
                "    while not done:",
                "        atomically:",
                "            if bq->count > 0:",
                "                result = bq->data[bq->head]",
                "                bq->head = (bq->head + 1) % bq->size",
                "                bq->count -= 1",
                "                done = True",
                "",
                "def bq_peek(bq):",
                "    done = False",
                "    while not done:",
                "        atomically:",
                "            if bq->count > 0:",
                "                result = bq->data[bq->head]",
                "                done = True",
                "",
                "def bq_clear(bq):",
                "    atomically:",
                "        bq->data = [None,] * bq->size",
                "        bq->count = 0",
                "        bq->head = 0",
                "        bq->tail = 0"
              ],
            "identifiers": {
                "BQueue": "constant",
                "bq": "local-const",
                "n": "local-const",
                "bq_put": "constant",
                "bq_peek": "constant",
                "this": "local-var",
                "v": "local-const",
                "bq_get": "constant",
                "___": "___",
                "bq_clear": "constant"
              }
          },
        "__main__": {
            "file": "bqueue_btest.hny",
            "lines": [
                "# Black-box differential test for blocking bounded queue",
                "# Import spec only u2014 do not dereference the queue pointer",
                "",
                "import bqueue",
                "",
                "const SIZE = 1",
                "const NPUT = 2",
                "const NGET = 2",
                "const NPEEK = 0",
                "const NCLEAR = 0",
                "",
                "myq = bqueue.BQueue(SIZE)",
                "",
                "def put_thread():",
                "    bqueue.bq_put(?myq, 1)",
                "",
                "def get_thread():",
                "    let v = bqueue.bq_get(?myq):",
                "        pass",
                "",
                "def peek_thread():",
                "    let v = bqueue.bq_peek(?myq):",
                "        pass",
                "",
                "def clear_thread():",
                "    bqueue.bq_clear(?myq)",
                "",
                "for i in {1..NPUT}:",
                "    spawn put_thread()",
                "",
                "for i in {1..NGET}:",
                "    spawn get_thread()",
                "",
                "for i in {1..NPEEK}:",
                "    spawn peek_thread()",
                "",
                "for i in {1..NCLEAR}:",
                "    spawn clear_thread()"
              ],
            "identifiers": {
                "NGET": "constant",
                "bqueue": "module",
                "NPEEK": "constant",
                "put_thread": "constant",
                "i": "local-const",
                "NCLEAR": "constant",
                "NPUT": "constant",
                "peek_thread": "constant",
                "this": "local-var",
                "v": "local-const",
                "get_thread": "constant",
                "clear_thread": "constant",
                "___": "___",
                "SIZE": "constant",
                "myq": "global"
              }
          }
      },
